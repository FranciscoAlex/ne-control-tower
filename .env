# ============================================================
# ENSA Control Tower — Environment Variables
# Copy to .env.local for local overrides
# ============================================================

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Main Application URL (where changes are visible)
VITE_MAIN_APP_URL=https://investorensa.up.railway.app

# Control Tower dev server port
VITE_PORT=4173
